# Local SQLite database used by Prisma. Keep the file URL relative to prisma.config.ts.
DATABASE_URL="file:./prisma/qulture.db"

# OpenAI is server-only. OPENAI_KEY is preferred; OPENAI_API_KEY is a supported fallback.
OPENAI_KEY=""
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.6-luna"

# Admin is disabled when ADMIN_PASSWORD is missing. Use a separate strong SESSION_SECRET in production.
ADMIN_PASSWORD=""
SESSION_SECRET=""

# Explicit local smoke mode. Production should keep this at 0; `?demo=1` is also development-only.
QULTURE_DEMO_COMMERCE="0"

# Emergency preview-only override. Production rejects PII capture while the active policy version is a draft.
QULTURE_ALLOW_DRAFT_PII_CAPTURE="0"

# Trust forwarded client-IP headers only behind a proxy you operate and configure.
TRUST_PROXY_HEADERS="false"

# Optional integration labels. Labels alone never enable checkout; concrete server adapters are still required.
PAYMENT_PROVIDER=""
DELIVERY_PROVIDER=""
ADDRESS_PROVIDER=""
FISCAL_PROVIDER=""

# Optional public origin for canonical metadata and signed order links.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
